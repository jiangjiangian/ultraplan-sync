# Doxyfile — Blueprint Phase 4 architecture-audit configuration.
#
# Generates a class hierarchy + per-directory dependency graph that the
# blueprint Phase-4 §A pass criteria are evaluated against:
#   1. ONE clean rooted tree (GameObject) + a separate non-rooted
#      utility/interface group (IRenderer, InputSource, IInteractable,
#      IChapterState). MFC's CObject + non-CObject discipline.
#   2. STRICT one-way directory DAG: app → ui → game → engine. Zero
#      back-edges (engine→game, game→ui). The `tools/check_layering.sh`
#      grep guard mirrors this for cheap CI gating.
#   3. raylib.h reachable ONLY from engine/* nodes (validates the
#      docs/CONVENTIONS.md §10 R5 confinement).
#
# Output (build/doxygen/, gitignored) is regenerated by:
#   cmake --build build --target docs       (the CMake custom target)
# or directly:
#   doxygen Doxyfile                         (from repo root)
#
# Settings not listed here fall back to doxygen 1.9 defaults — keeping
# the file minimal so diff-reviewers see only the project's deliberate
# overrides instead of 2,800 lines of stock defaults.

# ── Project identity ─────────────────────────────────────────────
PROJECT_NAME           = "尋傘記:政大山下篇"
PROJECT_BRIEF          = "C++20 / Raylib 5.5 top-down narrative RPG. Architecture audit."

# ── What to scan ────────────────────────────────────────────────
INPUT                  = include src
RECURSIVE              = YES
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
EXTRACT_ANON_NSPACES   = YES

# ── Graphs (Phase 4 §A) ─────────────────────────────────────────
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
DOT_CLEANUP            = NO
GRAPHICAL_HIERARCHY    = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
DIRECTORY_GRAPH        = YES
DOT_GRAPH_MAX_NODES    = 200
INTERACTIVE_SVG        = NO

# ── Output ─────────────────────────────────────────────────────
OUTPUT_DIRECTORY       = build/doxygen
GENERATE_LATEX         = NO
GENERATE_HTML          = YES
HTML_OUTPUT            = html
QUIET                  = YES
WARN_LOGFILE           = build/doxygen/warnings.log

# ── C++20 + reasonable defaults ────────────────────────────────
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = YES
BUILTIN_STL_SUPPORT    = YES
SORT_MEMBER_DOCS       = NO
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
ALWAYS_DETAILED_SEC    = YES
SHOW_USED_FILES        = YES
